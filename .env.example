# ===== OCTO-RADIOSTARR CONFIGURATION =====
# Environment variables for deployment (Docker Compose, systemd, etc.)
# These override the values in appsettings.json.
#
# NOTE: Use double-underscore (__) for nested properties in raw env keys.
# Example: Subsonic__Url maps to { "Subsonic": { "Url": "..." } }
# The keys below (UPPER_SNAKE) are the ones docker-compose.yml reads;
# they get translated into the proper Subsonic__ / Soulseek__ etc. forms.

# ===== SUBSONIC / NAVIDROME UPSTREAM =====
SUBSONIC_URL=http://localhost:4533
# Stream | Permanent | Cache
STORAGE_MODE=Stream
# Track | Album
DOWNLOAD_MODE=Track
DOWNLOAD_ON_STAR=true
# Flat = "Artist - Title.flac", Organized = "Artist/Album/Track.flac"
FOLDER_STRUCTURE=Flat
# Set true when DOWNLOAD_PATH is a cloud/FUSE mount (rclone, pCloud)
USE_LOCAL_STAGING=false
# All | ExplicitOnly | CleanOnly
EXPLICIT_FILTER=All
CACHE_DURATION_HOURS=1
ENABLE_EXTERNAL_PLAYLISTS=false

# Where downloaded FLACs land on the host. Bind-mounted into both Octo and slskd
# so star -> slskd writes -> Navidrome scans -> Octo serves all see the same path.
DOWNLOAD_PATH=./downloads

# ===== SOULSEEK (slskd) — permanent FLAC source on star =====
# slskd web UI / API admin credentials. Octo authenticates against /api/v0/session
# with these. They are *not* your Soulseek account credentials — see SOULSEEK_*
# below for those.
SLSKD_USERNAME=slskd
SLSKD_PASSWORD=slskd
SLSKD_SEARCH_WAIT_SECONDS=6
SLSKD_MIN_FILE_SIZE_BYTES=5242880
SLSKD_PREFERRED_EXTENSION=flac
SLSKD_DOWNLOAD_TIMEOUT_SECONDS=180

# Your Soulseek (Soulseek-network) account. Required for slskd to actually
# connect to peers and download. Sign up at https://www.slsknet.org/ if needed.
SLSKD_SOULSEEK_USERNAME=
SLSKD_SOULSEEK_PASSWORD=

# ===== YT-DLP SHIM (preview-stream sidecar) — usually leave defaults =====
YTDLP_MAX_CONCURRENT=5
YTDLP_SEARCH_CACHE_MAX=1024
YTDLP_URL_CACHE_MAX=512
YTDLP_URL_CACHE_TTL=3600

# ===== LAST.FM RADIO =====
# Get your API key at: https://www.last.fm/api/account/create
LASTFM_API_KEY=
LASTFM_ENABLE_RADIO=true
LASTFM_RADIO_TRACK_COUNT=50
LASTFM_RADIO_CACHE_HOURS=24
